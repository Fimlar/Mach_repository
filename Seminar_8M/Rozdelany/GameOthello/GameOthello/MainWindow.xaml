<Window x:Class="GameOthello.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameOthello"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid>
        <!--Rozdělení obrazovky podle zadání-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!--Label a Start tlačítko-->
        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical"
            HorizontalAlignment="Center" Margin="0, 40, 0, 0">
            <Label Content="Hra Othello" FontWeight="Bold" FontSize="28"/>
            <Button Command="{Binding StartCommand}" Content="Start Game"
            Background="Green" Foreground="White"/>
        </StackPanel>

        <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
            <!--Vytvořím uvnitř UniformGrid-->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="8" Rows="8"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.ClickCommand, 
                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            >
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Green"/>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding State}" Value="FirstPlayer">
                                        <Setter Property="Background" Value="Black"></Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="SecondPlayer">
                                        <Setter Property="Background" Value="White"></Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="Playable">
                                        <Setter Property="Background" Value="LightGreen"></Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Label Content="Hra začala"
               Visibility="{Binding IsGameRunning, Converter={StaticResource BoolToVis}}"
               Grid.Row="1"
               Grid.ColumnSpan="2"
               HorizontalAlignment="Center"
               FontSize="26"/>
    </Grid>
</Window>
