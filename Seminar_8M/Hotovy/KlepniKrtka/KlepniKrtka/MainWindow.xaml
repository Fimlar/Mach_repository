<Window x:Class="KlepniKrtka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KlepniKrtka"
        mc:Ignorable="d"
        Title="Klepni Krtka" Height="1080" Width="1920"
        Icon="/Pictures/krtek_na_trave.jpg">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        
        <!--Informativní Label s názvem hry-->
        <Label Grid.ColumnSpan="3" HorizontalAlignment="Center"
               VerticalAlignment="Center" FontSize="52" FontWeight="Bold">KLEPNI KRTKA</Label>
    
        <!--Stack panel na tlačítka vybírání obtížnosti-->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="20">
            <RadioButton Content="Začátečník" FontSize="20" Margin="10"
                         IsChecked="{Binding SelectedDifficulty, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Easy}"
                         Style="{StaticResource {x:Type ToggleButton}}"/>
            <RadioButton Content="Pokročilý" FontSize="20" Margin="10"
                         IsChecked="{Binding SelectedDifficulty, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Medium}"
                         Style="{StaticResource {x:Type ToggleButton}}"/>
            <RadioButton Content="Master" FontSize="20" Margin="10"
                         IsChecked="{Binding SelectedDifficulty, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Hard}"
                         Style="{StaticResource {x:Type ToggleButton}}"/>
            <Button Content="Stop" Command="{Binding StopCommand}" FontSize="20" Margin="10"/>
        </StackPanel>

        <!--Stack panel na tlačítko start a informace o krtcích-->
        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Vertical" Margin="20" HorizontalAlignment="Center">
            <Button  Content="Start" FontSize="20" Margin="10" Command="{Binding StartCommand}"/>
            <Label Content="Nachtáno krtků" FontSize="26"/>
            <Label Content="{Binding Score}" FontSize="26" HorizontalAlignment="Center"/>
        </StackPanel>
        
        <!--Label na ukazování zbývajícího času-->
        <Label Grid.Row="2" Grid.Column="1" FontSize="40" Content="{Binding RemainingTime}" HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <!--Hrací pole-->
        <ItemsControl Grid.Column="1" Grid.Row="1" ItemsSource="{Binding Cells}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="4" Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!--Nastavení toho, jak budou vypadat jednotlivá tlačítka-->
                    <Button Command="{Binding DataContext.ClickCommand, 
                                     RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Margin="5" 
                            Padding="0"
                            HorizontalContentAlignment="Stretch" 
                            VerticalContentAlignment="Stretch"
                            Cursor="{StaticResource ShovelCursor}">
                        <!--Nastavení toho, co bude v těch tlačítkách-->
                        <Image Stretch="UniformToFill">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Source" Value="/Pictures/trava.jpg"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMole}" Value="True">
                                            <Setter Property="Source" Value="/Pictures/krtek_na_trave.jpg"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
